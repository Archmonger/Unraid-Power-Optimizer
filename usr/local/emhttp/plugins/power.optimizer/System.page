Menu="power.optimizer:80"
Title="System Tunables"
---
<div class="power-section">
    <h2>System Tunables</h2>

    <p>
        System tunables focused on practical power savings. These settings can reduce power but may affect latency or device behavior depending on platform and workload.
    </p>

    <div class="settings-group">
        <div class="grid">
            <label class="toggle">
                <input type="checkbox" id="system-auto-startup-toggle">
                Auto Execute on Startup
            </label>

            <label class="toggle">
                <input type="checkbox" id="enable-audio-codec-pm-optimization" checked>
                Enable Audio Codec Power Management
            </label>

            <label class="toggle">
                <input type="checkbox" id="disable-nmi-watchdog" checked>
                Disable NMI Watchdog
            </label>

            <label class="toggle">
                <input type="checkbox" id="enable-vm-writeback-timeout-optimization" checked>
                Enable VM Writeback Timeout Optimization
            </label>

            <label class="toggle">
                <input type="checkbox" id="enable-disk-metadata-cache-warmup" checked>
                Immediately cache /mnt/disk*/ file metadata and folder structure
            </label>

            <label class="toggle">
                <input type="checkbox" id="enable-user-share-metadata-cache-warmup">
                Immediately cache /mnt/user/ file metadata and folder structure
            </label>

            <label class="toggle">
                <input type="checkbox" id="disable-numa-balancing" checked>
                Disable Automatic NUMA Balancing
            </label>
        </div>
    </div>

    <div class="settings-group">
        <div class="grid">
            <label>
                sched_mc_power_savings<br>
                <select id="power-aware-cpu-scheduler-mode">
                    <option value="0">0: no power savings</option>
                    <option value="1">1: use active cores first</option>
                    <option value="2">2: use active cores first and bias wakeups towards semi-idle cores</option>
                </select>
            </label>

            <label>
                mm.transparent_hugepage.enabled<br>
                <select id="thp-enabled-mode">
                    <option value="always">always</option>
                    <option value="madvise">madvise</option>
                    <option value="never">never</option>
                </select>
            </label>

            <label>
                mm.transparent_hugepage.defrag<br>
                <select id="thp-defrag-mode">
                    <option value="always">always</option>
                    <option value="defer">defer</option>
                    <option value="defer+madvise">defer+madvise</option>
                    <option value="madvise">madvise</option>
                    <option value="never">never</option>
                </select>
            </label>

            <label>
                Audio codec power_save (seconds)<br>
                <input type="number" id="audio-codec-power-save-seconds" min="0" max="60" step="1">
            </label>

            <label>
                vm.dirty_writeback_centisecs<br>
                <input type="number" id="vm-dirty-writeback-centisecs" min="100" max="60000" step="100">
            </label>

            <label>
                vm.laptop_mode<br>
                <input type="number" id="vm-laptop-mode" min="0" max="100" step="1">
            </label>

            <label>
                vm.dirty_expire_centisecs<br>
                <input type="number" id="vm-dirty-expire-centisecs" min="100" max="600000" step="100">
            </label>

            <label>
                vm.vfs_cache_pressure<br>
                <input type="number" id="vfs-cache-pressure" min="1" max="10000" step="1">
            </label>

            <label>
                vm.vfs_cache_max_age<br>
                <input type="number" id="vfs-cache-max-age" min="1" max="31536000" step="1">
            </label>

            <label>
                zfs_arc_min (% of RAM, 0 to disable)<br>
                <input type="number" id="zfs-arc-min-percent" min="0" max="100" step="1">
            </label>

            <label>
                zfs_arc_max (% of RAM, 0 to disable)<br>
                <input type="number" id="zfs-arc-max-percent" min="0" max="100" step="1">
            </label>
        </div>
    </div>

    <div class="row">
        <button type="button" class="btn" id="system-save-button">Save Settings</button>
        <button type="button" class="btn" id="system-run-button">Run Now</button>
    </div>

    <br>
    <hr>
    <br>

    <div id="system-status-message" class="status-message" aria-live="polite">[--:--:--] Ready.</div>
    <pre id="system-status" class="terminal-box">$ waiting for optimizer output...</pre>
</div>

<style>
.power-section { max-width: 980px; }
.settings-group { margin: 12px 0; }
.grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 10px; margin: 10px 0; }
.toggle { display: inline-flex; align-items: center; gap: 8px; }
.row { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 10px; }
.status-message {
    margin-top: 10px;
    padding: 8px 10px;
    border-radius: 4px;
    border: 1px solid #d1d5db;
    background: #f3f4f6;
    color: #1f2937;
    white-space: pre-wrap;
}
.status-message.error {
    border-color: #b91c1c;
    background: #fee2e2;
    color: #7f1d1d;
}
.terminal-box {
    margin-top: 10px;
    background: #0b1220;
    color: #d4f7d0;
    padding: 12px;
    border-radius: 4px;
    border: 1px solid #243145;
    white-space: pre-wrap;
    font-family: Consolas, "Courier New", monospace;
    min-height: 220px;
    max-height: 420px;
    overflow: auto;
}
input[type="number"] { width: 100%; }
</style>

<script>
(function () {
    const endpoint = '/plugins/power.optimizer/include/actions.php';
    const executionLogScope = 'system';
    const executionLogLines = 220;
    const executionLogPollMs = 1000;

    const autoStartupToggle = document.getElementById('system-auto-startup-toggle');
    const enableAudioCodecPm = document.getElementById('enable-audio-codec-pm-optimization');
    const audioCodecPowerSaveSeconds = document.getElementById('audio-codec-power-save-seconds');
    const disableNmiWatchdog = document.getElementById('disable-nmi-watchdog');
    const enableVmWritebackTimeoutOptimization = document.getElementById('enable-vm-writeback-timeout-optimization');
    const vmDirtyWritebackCentisecs = document.getElementById('vm-dirty-writeback-centisecs');
    const vmLaptopMode = document.getElementById('vm-laptop-mode');
    const vmDirtyExpireCentisecs = document.getElementById('vm-dirty-expire-centisecs');
    const vfsCachePressure = document.getElementById('vfs-cache-pressure');
    const vfsCacheMaxAge = document.getElementById('vfs-cache-max-age');
    const enableDiskMetadataCacheWarmup = document.getElementById('enable-disk-metadata-cache-warmup');
    const enableUserShareMetadataCacheWarmup = document.getElementById('enable-user-share-metadata-cache-warmup');
    const zfsArcMinPercent = document.getElementById('zfs-arc-min-percent');
    const zfsArcMaxPercent = document.getElementById('zfs-arc-max-percent');
    const powerAwareSchedulerMode = document.getElementById('power-aware-cpu-scheduler-mode');
    const thpEnabledMode = document.getElementById('thp-enabled-mode');
    const thpDefragMode = document.getElementById('thp-defrag-mode');
    const disableNumaBalancing = document.getElementById('disable-numa-balancing');

    const saveButton = document.getElementById('system-save-button');
    const runButton = document.getElementById('system-run-button');
    const statusMessage = document.getElementById('system-status-message');
    const status = document.getElementById('system-status');

    const state = {
        executionLogPath: '/boot/logs/power.optimizer-system-tunables.log',
        executionLogTail: '',
        savedSettingsSignature: ''
    };

    let executionLogTimer = null;

    function nowTimestamp() {
        return new Date().toLocaleTimeString('en-US', { hour12: false });
    }

    function renderTerminal() {
        const lines = [];
        lines.push('$ tail -n ' + executionLogLines + ' ' + state.executionLogPath);
        lines.push(state.executionLogTail || '(no command output yet)');
        status.textContent = lines.join('\n');
        status.scrollTop = status.scrollHeight;
    }

    function setStatus(text, isError) {
        if (!statusMessage) {
            return;
        }

        statusMessage.textContent = '[' + nowTimestamp() + '] ' + text;
        statusMessage.className = 'status-message' + (isError ? ' error' : '');
    }

    async function postAction(action, payload) {
        const body = new URLSearchParams();
        body.set('action', action);
        const csrfTokenField = document.querySelector('input[name="csrf_token"]');
        const csrfTokenMeta = document.querySelector('meta[name="csrf_token"]');
        const csrfToken = (csrfTokenField && csrfTokenField.value)
            || (csrfTokenMeta && csrfTokenMeta.content)
            || window.csrf_token
            || '';
        if (csrfToken) {
            body.set('csrf_token', csrfToken);
        }
        Object.keys(payload || {}).forEach((key) => body.set(key, payload[key]));

        const response = await fetch(endpoint, {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded;charset=UTF-8' },
            body: body.toString()
        });

        const responseText = await response.text();
        if (!responseText.trim()) {
            throw new Error('Empty response from plugin backend.');
        }

        let data;
        try {
            data = JSON.parse(responseText);
        } catch (error) {
            throw new Error('Invalid response from plugin backend.');
        }

        return data;
    }

    async function loadExecutionLogOutput() {
        const data = await postAction('get_execution_log_output', {
            scope: executionLogScope,
            lines: String(executionLogLines)
        });

        if (!data.ok) {
            throw new Error(data.message || 'Failed to load execution log output.');
        }

        if (data.log) {
            state.executionLogPath = data.log;
        }

        state.executionLogTail = data.output || '';
        renderTerminal();
    }

    function isExecutionLogPollingAllowed() {
        if (document.hidden) {
            return false;
        }

        return Boolean(status && status.offsetParent !== null);
    }

    function startExecutionLogPolling() {
        if (executionLogTimer !== null) {
            return;
        }

        executionLogTimer = window.setInterval(function () {
            if (!isExecutionLogPollingAllowed()) {
                return;
            }

            loadExecutionLogOutput().catch(function (error) {
                setStatus('Log refresh failed: ' + error.message, true);
            });
        }, executionLogPollMs);
    }

    function collectSettingsPayload() {
        return {
            auto_execute_on_startup: autoStartupToggle.checked ? '1' : '0',
            enable_audio_codec_pm_optimization: enableAudioCodecPm.checked ? '1' : '0',
            audio_codec_power_save_seconds: audioCodecPowerSaveSeconds.value,
            disable_nmi_watchdog: disableNmiWatchdog.checked ? '1' : '0',
            enable_vm_writeback_timeout_optimization: enableVmWritebackTimeoutOptimization.checked ? '1' : '0',
            vm_dirty_writeback_centisecs: vmDirtyWritebackCentisecs.value,
            vm_laptop_mode: vmLaptopMode.value,
            vm_dirty_expire_centisecs: vmDirtyExpireCentisecs.value,
            vfs_cache_pressure: vfsCachePressure.value,
            vfs_cache_max_age: vfsCacheMaxAge.value,
            enable_disk_metadata_cache_warmup: enableDiskMetadataCacheWarmup.checked ? '1' : '0',
            enable_user_share_metadata_cache_warmup: enableUserShareMetadataCacheWarmup.checked ? '1' : '0',
            zfs_arc_min_percent: zfsArcMinPercent.value,
            zfs_arc_max_percent: zfsArcMaxPercent.value,
            power_aware_cpu_scheduler_mode: powerAwareSchedulerMode.value,
            thp_enabled_mode: thpEnabledMode.value,
            thp_defrag_mode: thpDefragMode.value,
            disable_numa_balancing: disableNumaBalancing.checked ? '1' : '0'
        };
    }

    function settingsSignature(payload) {
        return JSON.stringify(payload);
    }

    function updateSaveButtonState() {
        if (state.savedSettingsSignature === '') {
            saveButton.disabled = true;
            return;
        }

        saveButton.disabled = settingsSignature(collectSettingsPayload()) === state.savedSettingsSignature;
    }

    function markSettingsSaved() {
        state.savedSettingsSignature = settingsSignature(collectSettingsPayload());
        updateSaveButtonState();
    }

    function registerDirtyTracking() {
        [
            autoStartupToggle,
            enableAudioCodecPm,
            audioCodecPowerSaveSeconds,
            disableNmiWatchdog,
            enableVmWritebackTimeoutOptimization,
            vmDirtyWritebackCentisecs,
            vmLaptopMode,
            vmDirtyExpireCentisecs,
            vfsCachePressure,
            vfsCacheMaxAge,
            enableDiskMetadataCacheWarmup,
            enableUserShareMetadataCacheWarmup,
            zfsArcMinPercent,
            zfsArcMaxPercent,
            powerAwareSchedulerMode,
            thpEnabledMode,
            thpDefragMode,
            disableNumaBalancing
        ].forEach(function (element) {
            element.addEventListener('change', updateSaveButtonState);
            element.addEventListener('input', updateSaveButtonState);
        });
    }

    function applySettings(settings) {
        autoStartupToggle.checked = Number(settings.auto_execute_on_startup || 0) === 1;
        enableAudioCodecPm.checked = Number(settings.enable_audio_codec_pm_optimization || 0) === 1;
        audioCodecPowerSaveSeconds.value = String(settings.audio_codec_power_save_seconds || 1);

        disableNmiWatchdog.checked = Number(settings.disable_nmi_watchdog || 0) === 1;

        enableVmWritebackTimeoutOptimization.checked = Number(settings.enable_vm_writeback_timeout_optimization || 0) === 1;
        vmDirtyWritebackCentisecs.value = String(settings.vm_dirty_writeback_centisecs || 1500);
        vmLaptopMode.value = String(settings.vm_laptop_mode ?? 5);
        vmDirtyExpireCentisecs.value = String(settings.vm_dirty_expire_centisecs ?? 6000);
        vfsCachePressure.value = String(settings.vfs_cache_pressure ?? 1);
        vfsCacheMaxAge.value = String(settings.vfs_cache_max_age ?? 60000);
        enableDiskMetadataCacheWarmup.checked = Number(settings.enable_disk_metadata_cache_warmup ?? 1) === 1;
        enableUserShareMetadataCacheWarmup.checked = Number(settings.enable_user_share_metadata_cache_warmup ?? 0) === 1;
        zfsArcMinPercent.value = String(settings.zfs_arc_min_percent ?? 10);
        zfsArcMaxPercent.value = String(settings.zfs_arc_max_percent ?? 40);
        thpEnabledMode.value = settings.thp_enabled_mode || 'madvise';
        thpDefragMode.value = settings.thp_defrag_mode || 'defer+madvise';

        powerAwareSchedulerMode.value = String(settings.power_aware_cpu_scheduler_mode || 2);
        const disableNumaBalancingValue = settings.disable_numa_balancing ?? 1;
        disableNumaBalancing.checked = Number(disableNumaBalancingValue) === 1;
        markSettingsSaved();
    }

    async function loadSettings() {
        const data = await postAction('get_system_tunables_settings', {});
        if (!data.ok) {
            throw new Error(data.message || 'Failed to load System Tunables settings.');
        }
        applySettings(data.settings || {});
    }

    async function saveSettings(silent) {
        if (!silent) {
            setStatus('Saving System Tunables settings...', false);
        }

        const data = await postAction('save_system_tunables_settings', collectSettingsPayload());
        if (!data.ok) {
            throw new Error(data.message || 'Save failed.');
        }

        applySettings(data.settings || {});

        if (!silent) {
            setStatus(data.message || 'System Tunables settings saved.', false);
        }

        return data;
    }

    saveButton.addEventListener('click', async function () {
        try {
            await saveSettings(false);
        } catch (error) {
            setStatus('Save failed: ' + error.message, true);
        }
    });

    runButton.addEventListener('click', async function () {
        try {
            setStatus('Saving System Tunables settings before run...', false);
            await saveSettings(true);

            setStatus('Starting System Tunables optimization...', false);
            const data = await postAction('run_system_tunables_optimization', {});
            if (!data.ok) {
                setStatus(data.message || 'Run failed.', true);
                return;
            }
            state.executionLogPath = data.log || state.executionLogPath;
            setStatus((data.message || 'System Tunables optimization started.') + ' Log: ' + state.executionLogPath, false);
            await loadExecutionLogOutput();
        } catch (error) {
            setStatus('Run failed: ' + error.message, true);
        }
    });

    renderTerminal();
    startExecutionLogPolling();
    registerDirtyTracking();
    updateSaveButtonState();

    Promise.all([loadSettings(), loadExecutionLogOutput()]).catch(function (error) {
        setStatus('Initialization failed: ' + error.message, true);
    });
})();
</script>
