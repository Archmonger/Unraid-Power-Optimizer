Menu="power.optimizer:30"
Title="CPU"
---
<div class="power-section">
    <h2>CPU Power Management</h2>

    <p>
        Configure CPU governor and turbo behavior for power savings.
    </p>

    <div class="grid">
        <label class="toggle">
            <input type="checkbox" id="cpu-auto-startup-toggle">
            Auto Execute on Startup
        </label>

        <label>
            Modify CPU Governor<br>
            <select id="cpu-governor-mode"></select>
        </label>

        <label id="cpu-turbo-control">
            Modify CPU Turbo<br>
            <select id="cpu-turbo-mode">
                <option value="disabled">disabled</option>
                <option value="force_enabled">force enabled</option>
                <option value="force_disabled">force disabled</option>
            </select>
        </label>
    </div>

    <div class="row">
        <button type="button" class="btn" id="cpu-save-button">Save Settings</button>
        <button type="button" class="btn" id="cpu-run-button">Run Now</button>
    </div>

    <div id="cpu-status-message" class="status-message" aria-live="polite">[--:--:--] Ready.</div>
    <pre id="cpu-status" class="terminal-box">$ waiting for optimizer output...</pre>
</div>

<style>
.power-section { max-width: 980px; }
.grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 10px; margin: 10px 0; }
.toggle { display: inline-flex; align-items: center; gap: 8px; }
.row { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 10px; }
.status-message {
    margin-top: 10px;
    padding: 8px 10px;
    border-radius: 4px;
    border: 1px solid #d1d5db;
    background: #f3f4f6;
    color: #1f2937;
    white-space: pre-wrap;
}
.status-message.error {
    border-color: #b91c1c;
    background: #fee2e2;
    color: #7f1d1d;
}
.terminal-box {
    margin-top: 10px;
    background: #0b1220;
    color: #d4f7d0;
    padding: 12px;
    border-radius: 4px;
    border: 1px solid #243145;
    white-space: pre-wrap;
    font-family: Consolas, "Courier New", monospace;
    min-height: 220px;
    max-height: 420px;
    overflow: auto;
}
</style>

<script>
(function () {
    const endpoint = '/plugins/power.optimizer/include/actions.php';
    const executionLogScope = 'cpu';
    const executionLogLines = 220;
    const executionLogPollMs = 1000;

    const autoStartupToggle = document.getElementById('cpu-auto-startup-toggle');
    const governorMode = document.getElementById('cpu-governor-mode');
    const turboControl = document.getElementById('cpu-turbo-control');
    const turboMode = document.getElementById('cpu-turbo-mode');
    const saveButton = document.getElementById('cpu-save-button');
    const runButton = document.getElementById('cpu-run-button');
    const statusMessage = document.getElementById('cpu-status-message');
    const status = document.getElementById('cpu-status');

    const state = {
        executionLogPath: '/boot/logs/power.optimizer-cpu.log',
        executionLogTail: '',
        savedSettingsSignature: '',
        availableGovernors: [],
        supportsCpuTurbo: false
    };

    let executionLogTimer = null;

    function nowTimestamp() {
        return new Date().toLocaleTimeString('en-US', { hour12: false });
    }

    function renderTerminal() {
        const lines = [];
        lines.push('$ tail -n ' + executionLogLines + ' ' + state.executionLogPath);
        lines.push(state.executionLogTail || '(no command output yet)');
        status.textContent = lines.join('\n');
        status.scrollTop = status.scrollHeight;
    }

    function setStatus(text, isError) {
        if (!statusMessage) {
            return;
        }

        statusMessage.textContent = '[' + nowTimestamp() + '] ' + text;
        statusMessage.className = 'status-message' + (isError ? ' error' : '');
    }

    async function postAction(action, payload) {
        const body = new URLSearchParams();
        body.set('action', action);
        const csrfTokenField = document.querySelector('input[name="csrf_token"]');
        const csrfTokenMeta = document.querySelector('meta[name="csrf_token"]');
        const csrfToken = (csrfTokenField && csrfTokenField.value)
            || (csrfTokenMeta && csrfTokenMeta.content)
            || window.csrf_token
            || '';
        if (csrfToken) {
            body.set('csrf_token', csrfToken);
        }
        Object.keys(payload || {}).forEach((key) => body.set(key, payload[key]));

        const response = await fetch(endpoint, {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded;charset=UTF-8' },
            body: body.toString()
        });

        const responseText = await response.text();
        if (!responseText.trim()) {
            throw new Error('Empty response from plugin backend.');
        }

        let data;
        try {
            data = JSON.parse(responseText);
        } catch (error) {
            throw new Error('Invalid response from plugin backend.');
        }

        return data;
    }

    async function loadExecutionLogOutput() {
        const data = await postAction('get_execution_log_output', {
            scope: executionLogScope,
            lines: String(executionLogLines)
        });

        if (!data.ok) {
            throw new Error(data.message || 'Failed to load execution log output.');
        }

        if (data.log) {
            state.executionLogPath = data.log;
        }

        state.executionLogTail = data.output || '';
        renderTerminal();
    }

    function isExecutionLogPollingAllowed() {
        if (document.hidden) {
            return false;
        }

        return Boolean(status && status.offsetParent !== null);
    }

    function startExecutionLogPolling() {
        if (executionLogTimer !== null) {
            return;
        }

        executionLogTimer = window.setInterval(function () {
            if (!isExecutionLogPollingAllowed()) {
                return;
            }

            loadExecutionLogOutput().catch(function (error) {
                setStatus('Log refresh failed: ' + error.message, true);
            });
        }, executionLogPollMs);
    }

    function collectSettingsPayload() {
        return {
            auto_execute_on_startup: autoStartupToggle.checked ? '1' : '0',
            cpu_governor_mode: governorMode.value,
            cpu_turbo_mode: turboMode.value
        };
    }

    function normalizeGovernorList(governors) {
        const allowed = ['powersave', 'ondemand', 'conservative', 'schedutil', 'performance'];
        const seen = Object.create(null);
        const result = [];

        (governors || []).forEach(function (value) {
            const normalized = String(value || '').toLowerCase();
            if (allowed.indexOf(normalized) === -1 || seen[normalized]) {
                return;
            }
            seen[normalized] = true;
            result.push(normalized);
        });

        return result;
    }

    function preferredGovernorDefault() {
        return state.availableGovernors.indexOf('powersave') !== -1 ? 'powersave' : 'disabled';
    }

    function populateGovernorOptions(selectedMode) {
        const options = [{ value: 'disabled', label: 'disabled' }]
            .concat(state.availableGovernors.map(function (governor) {
                return { value: governor, label: governor };
            }));

        governorMode.innerHTML = '';
        options.forEach(function (optionData) {
            const option = document.createElement('option');
            option.value = optionData.value;
            option.textContent = optionData.label;
            governorMode.appendChild(option);
        });

        const fallback = preferredGovernorDefault();
        const nextMode = options.some(function (item) {
            return item.value === selectedMode;
        }) ? selectedMode : fallback;
        governorMode.value = nextMode;
    }

    function updateTurboControlVisibility() {
        turboControl.style.display = state.supportsCpuTurbo ? '' : 'none';
        if (!state.supportsCpuTurbo) {
            turboMode.value = 'disabled';
        }
    }

    function settingsSignature(payload) {
        return JSON.stringify(payload);
    }

    function updateSaveButtonState() {
        if (state.savedSettingsSignature === '') {
            saveButton.disabled = true;
            return;
        }

        saveButton.disabled = settingsSignature(collectSettingsPayload()) === state.savedSettingsSignature;
    }

    function markSettingsSaved() {
        state.savedSettingsSignature = settingsSignature(collectSettingsPayload());
        updateSaveButtonState();
    }

    function registerDirtyTracking() {
        [autoStartupToggle, governorMode, turboMode].forEach(function (element) {
            element.addEventListener('change', updateSaveButtonState);
            element.addEventListener('input', updateSaveButtonState);
        });
    }

    function applySettings(settings, capabilities) {
        const caps = capabilities || {};
        state.availableGovernors = normalizeGovernorList(caps.available_governors);
        state.supportsCpuTurbo = Boolean(caps.supports_cpu_turbo);

        autoStartupToggle.checked = Number(settings.auto_execute_on_startup || 0) === 1;

        const selectedGovernorMode = settings.cpu_governor_mode || preferredGovernorDefault();
        populateGovernorOptions(selectedGovernorMode);

        const selectedTurboMode = settings.cpu_turbo_mode || 'disabled';
        if (['disabled', 'force_enabled', 'force_disabled'].indexOf(selectedTurboMode) !== -1) {
            turboMode.value = selectedTurboMode;
        } else {
            turboMode.value = 'disabled';
        }
        updateTurboControlVisibility();
        markSettingsSaved();
    }

    async function loadSettings() {
        const data = await postAction('get_cpu_settings', {});
        if (!data.ok) {
            throw new Error(data.message || 'Failed to load CPU settings.');
        }
        applySettings(data.settings || {}, data.capabilities || {});
    }

    async function saveSettings(silent) {
        if (!silent) {
            setStatus('Saving CPU settings...', false);
        }

        const data = await postAction('save_cpu_settings', collectSettingsPayload());
        if (!data.ok) {
            throw new Error(data.message || 'Save failed.');
        }

        applySettings(data.settings || {}, data.capabilities || {});

        if (!silent) {
            setStatus(data.message || 'CPU settings saved.', false);
        }

        return data;
    }

    saveButton.addEventListener('click', async function () {
        try {
            await saveSettings(false);
        } catch (error) {
            setStatus('Save failed: ' + error.message, true);
        }
    });

    runButton.addEventListener('click', async function () {
        try {
            setStatus('Saving CPU settings before run...', false);
            await saveSettings(true);

            setStatus('Starting CPU optimization...', false);
            const data = await postAction('run_cpu_optimization', {});
            if (!data.ok) {
                setStatus(data.message || 'Run failed.', true);
                return;
            }
            state.executionLogPath = data.log || state.executionLogPath;
            setStatus((data.message || 'CPU optimization started.') + ' Log: ' + state.executionLogPath, false);
            await loadExecutionLogOutput();
        } catch (error) {
            setStatus('Run failed: ' + error.message, true);
        }
    });

    renderTerminal();
    startExecutionLogPolling();
    registerDirtyTracking();
    updateSaveButtonState();

    Promise.all([loadSettings(), loadExecutionLogOutput()]).catch(function (error) {
        setStatus('Initialization failed: ' + error.message, true);
    });
})();
</script>
